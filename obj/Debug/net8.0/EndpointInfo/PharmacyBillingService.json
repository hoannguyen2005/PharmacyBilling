  "components": {
    "schemas": {
      "CreateInvoiceDto": {
        "required": [
          "examinationFee",
          "prescriptionId"
        ],
        "type": "object",
        "properties": {
          "prescriptionId": {
            "type": "integer",
            "format": "int32"
          },
          "examinationFee": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreateMedicineDto": {
        "required": [
          "medicineName",
          "minStockLevel",
          "price",
          "stockQuantity",
          "unit"
        ],
        "type": "object",
        "properties": {
          "medicineName": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "activeIngredient": {
            "maxLength": 150,
            "type": "string",
            "nullable": true
          },
          "unit": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "stockQuantity": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "minStockLevel": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "expiryDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PayInvoiceDto": {
        "required": [
          "paymentMethod"
        ],
        "type": "object",
        "properties": {
          "paymentMethod": {
            "minLength": 1,
            "pattern": "^(Cash|Banking|Card|Momo|Other)$",
            "type": "string"
          },
          "note": {
            "maxLength": 255,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PrescriptionCreatedEvent": {
        "type": "object",
        "properties": {
          "eventName": {
            "type": "string",
            "nullable": true
          },
          "prescriptionId": {
            "type": "integer",
            "format": "int32"
          },
          "patientId": {
            "type": "integer",
            "format": "int32"
          },
          "doctorId": {
            "type": "integer",
            "format": "int32"
          },
          "appointmentId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "medicalRecordId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrescriptionCreatedItemEvent"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PrescriptionCreatedItemEvent": {
        "type": "object",
        "properties": {
          "medicineId": {
            "type": "integer",
            "format": "int32"
          },
          "medicineName": {
            "type": "string",
            "nullable": true
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "dosage": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "required": [
          "email",
          "fullName",
          "password",
          "role"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "maxLength": 100,
            "minLength": 6,
            "type": "string"
          },
          "role": {
            "minLength": 1,
            "pattern": "^(Admin|Doctor|Receptionist|Nurse|Patient)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "StockAdjustDto": {
        "required": [
          "medicineId",
          "newQuantity"
        ],
        "type": "object",
        "properties": {
          "medicineId": {
            "type": "integer",
            "format": "int32"
          },
          "newQuantity": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "reason": {
            "maxLength": 255,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StockImportDto": {
        "required": [
          "medicineId",
          "quantity"
        ],
        "type": "object",
        "properties": {
          "medicineId": {
            "type": "integer",
            "format": "int32"
          },
          "quantity": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "reason": {
            "maxLength": 255,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateMedicineDto": {
        "required": [
          "medicineName",
          "minStockLevel",
          "price",
          "status",
          "stockQuantity",
          "unit"
        ],
        "type": "object",
        "properties": {
          "medicineName": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "activeIngredient": {
            "maxLength": 150,
            "type": "string",
            "nullable": true
          },
          "unit": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "stockQuantity": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "minStockLevel": {
            "maximum": 2147483647,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "expiryDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "status": {
            "minLength": 1,
            "pattern": "^(Active|Inactive|OutOfStock)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
